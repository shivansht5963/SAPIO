### FFMS API Test File
# Use with VS Code REST Client extension or similar

@baseUrl = http://127.0.0.1:8000/api
@adminUsername = admin_user
@adminPassword = admin123
@leadUsername = tl_alpha
@leadPassword = pass123
@agentUsername = agent_ravi
@agentPassword = pass123

### 1. Login as Admin
# @name adminLogin
POST {{baseUrl}}/auth/login/
Content-Type: application/json

{
    "username": "{{adminUsername}}",
    "password": "{{adminPassword}}"
}

###
@adminToken = {{adminLogin.response.body.access}}

### 2. Login as Team Lead
# @name leadLogin
POST {{baseUrl}}/auth/login/
Content-Type: application/json

{
    "username": "{{leadUsername}}",
    "password": "{{leadPassword}}"
}

###
@leadToken = {{leadLogin.response.body.access}}

### 3. Login as Field Agent
# @name agentLogin
POST {{baseUrl}}/auth/login/
Content-Type: application/json

{
    "username": "{{agentUsername}}",
    "password": "{{agentPassword}}"
}

###
@agentToken = {{agentLogin.response.body.access}}

### 4. Login as Auditor
# @name auditorLogin
POST {{baseUrl}}/auth/login/
Content-Type: application/json

{
    "username": "auditor_meera",
    "password": "pass123"
}

###
@auditorToken = {{auditorLogin.response.body.access}}

### ----------------------------------------------------
### Tasks APIs
### ----------------------------------------------------

### List all tasks (Admin sees all)
GET {{baseUrl}}/tasks/
Authorization: Bearer {{adminToken}}

### List tasks (Lead sees team tasks)
GET {{baseUrl}}/tasks/
Authorization: Bearer {{leadToken}}

### List tasks (Agent sees only own assigned tasks)
GET {{baseUrl}}/tasks/
Authorization: Bearer {{agentToken}}

### Create a Task (Lead can create)
POST {{baseUrl}}/tasks/
Authorization: Bearer {{leadToken}}
Content-Type: application/json

{
    "title": "New Team Task",
    "description": "Created by Team Lead via API",
    "priority": "medium",
    "due_date": "2026-06-01"
}

### Create a Task (Agent gets 403 Forbidden)
POST {{baseUrl}}/tasks/
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "title": "Agent created task",
    "description": "Should be forbidden",
    "priority": "low",
    "due_date": "2026-06-01"
}

### Get Task Detail (In scope)
# Replace {id} with a valid task ID for the user
GET {{baseUrl}}/tasks/1/
Authorization: Bearer {{leadToken}}

### Assign/Re-assign Task
# Replace {id} with a valid task ID and `assigned_to` with an EmployeeProfile ID
PATCH {{baseUrl}}/tasks/1/assign/
Authorization: Bearer {{leadToken}}
Content-Type: application/json

{
    "assigned_to": 5
}

### ----------------------------------------------------
### Visits APIs
### ----------------------------------------------------

### Start a Visit (Agent)
# Replace `task_id` with a task assigned to agent_ravi
POST {{baseUrl}}/visits/start/
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "task_id": 20
}

### Complete a Visit (Low Risk)
# Replace {id} with the ID of the visit created above
POST {{baseUrl}}/visits/10/complete/
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "visit_notes": "Customer was happy, routine check completed."
}

### Complete a Visit (High Risk)
# Replace {id} with another active visit ID
POST {{baseUrl}}/visits/10/complete/
Authorization: Bearer {{agentToken}}
Content-Type: application/json

{
    "visit_notes": "Customer was extremely angry and refused to sign."
}

### Get Visit Detail (Manager)
# Replace {id} with the visit ID
GET {{baseUrl}}/visits/10/
Authorization: Bearer {{leadToken}}


### ----------------------------------------------------
### Activity Logs APIs
### ----------------------------------------------------

### Fetch Logs (Auditor - sees all)
GET {{baseUrl}}/logs/
Authorization: Bearer {{auditorToken}}

### Fetch Logs with Filter
GET {{baseUrl}}/logs/?action=completed&entity_type=visit
Authorization: Bearer {{auditorToken}}

### Fetch Logs (Agent - forbidden)
GET {{baseUrl}}/logs/
Authorization: Bearer {{agentToken}}


### ----------------------------------------------------
### Reports & Dashboard APIs
### ----------------------------------------------------

### Pending Tasks (grouped by region+team)
GET {{baseUrl}}/reports/pending-tasks/
Authorization: Bearer {{adminToken}}

### Task Distribution (status counts per region)
GET {{baseUrl}}/reports/task-distribution/
Authorization: Bearer {{auditorToken}}

### Recent Visits (completed in last 7 days, daily)
GET {{baseUrl}}/reports/recent-visits/
Authorization: Bearer {{leadToken}}

### Avg Completion Time per Agent
GET {{baseUrl}}/reports/completion-time/
Authorization: Bearer {{adminToken}}

### Dashboard (Admin - global view)
GET {{baseUrl}}/reports/dashboard/
Authorization: Bearer {{adminToken}}

### Dashboard (Agent - self-scoped view)
GET {{baseUrl}}/reports/dashboard/
Authorization: Bearer {{agentToken}}
